{
  "manifest_version": 3,
  "name": "QA Issue Creator",
  "version": "0.0.11",
  "description": "Capture exploratory QA context and create Jira issues faster.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.robjmichaels.com/*",
    "https://robjmichaels.com/*",
    "https://*.hardmileoutfitters.com/*",
    "https://hardmileoutfitters.com/*",
    "https://*.exquisitepets.shop/*",
    "https://exquisitepets.shop/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*",
    "https://rob-michaels.atlassian.net/*",
    "https://*.atlassian.net/*"
  ],
  "background": {
    "service_worker": "sw/qa_issue_background_service.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.robjmichaels.com/*",
        "https://robjmichaels.com/*",
        "https://*.hardmileoutfitters.com/*",
        "https://hardmileoutfitters.com/*",
        "https://*.exquisitepets.shop/*",
        "https://exquisitepets.shop/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "content/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
